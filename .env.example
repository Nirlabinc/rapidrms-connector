# Server
PORT=3000
NODE_ENV=development

# Supabase (for SaaS version)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Encryption Master Key (for credential storage)
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=your-32-byte-hex-key

# RapidRMS Credentials (for local/dev mode without Supabase)
RAPIDRMS_CLIENT_ID=2
RAPIDRMS_EMAIL=your-email@example.com
RAPIDRMS_PASSWORD=your-password
RAPIDRMS_API_BASE=https://rapidrmsapi.azurewebsites.net

# Logging
LOG_LEVEL=info
